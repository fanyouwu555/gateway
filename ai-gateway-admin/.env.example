# AI Gateway Admin Frontend Environment Variables
# 复制为 .env 并填入实际值

# 跳过登录页（开发模式）
VITE_API_KEY=admin-dashboard-key-456

# API 基础 URL（默认通过 Vite proxy 到 localhost:3000）
# VITE_API_BASE_URL=/api

# WebSocket 基础 URL（默认 ws://localhost:3000）
# VITE_WS_BASE_URL=ws://localhost:3000

# ── 后端 Provider 环境变量参考 ────────────────────────────────────────────────
# VOLCANO_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
#
# KIMI_CODE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
