# =============================================================================
# AI Gateway — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# 优先级: 环境变量 > 配置文件 (conf/default.json)
# =============================================================================

# ── 服务基础配置 ──────────────────────────────────────────────────────────
PORT=3000                           # 服务端口
HOST=0.0.0.0                        # 监听地址
LOG_LEVEL=info                      # 日志级别: debug | info | warn | error
NODE_ENV=development                 # 运行环境: development | production
CONFIG_PATH=./conf/default.json     # 配置文件路径

# ── Provider API Keys ─────────────────────────────────────────────────────
# OpenAI / OpenAI 兼容接口
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Mistral
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google / Gemini
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Moonshot (Kimi)
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# ── 网关 API Keys（多个用逗号分隔） ────────────────────────────────────────
# 客户端调用网关时的认证凭据，可在 conf/default.json 的 auth.api_keys 中配置更多
API_KEYS=sk-gateway-key-1,sk-gateway-key-2

# 管理员 API Keys（多个用逗号分隔，拥有管理后台权限）
# API_ADMIN_KEYS=sk-admin-key-1,sk-admin-key-2

# ── Redis 配置 ─────────────────────────────────────────────────────────────
# 方式一: 直接使用 URL（优先级高）
# REDIS_URL=redis://:password@localhost:6379/0

# 方式二: 逐项配置
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_PREFIX=gateway
# REDIS_MAX_RETRIES=3

# ── 各模块存储后端 ────────────────────────────────────────────────────────
# 默认使用内存存储，设为 'redis' 切换到 Redis
STORAGE_TYPE=memory                  # 全局默认存储: memory | redis
CACHE_STORAGE=memory                 # 缓存存储
HISTORY_STORAGE=memory               # 会话历史存储
METRICS_STORAGE=memory               # 用量统计存储
RATE_LIMIT_STORAGE=memory            # 限流存储（设为 redis 启用分布式限流）

# ── Failover 配置（可选） ─────────────────────────────────────────────────
# FAILOVER_ENABLED=false
# FAILOVER_FAILURE_THRESHOLD=3
# FAILOVER_SUCCESS_THRESHOLD=2
# FAILOVER_HEALTH_CHECK_INTERVAL=60000
# FAILOVER_HEALTH_CHECK_TIMEOUT=5000
# FAILOVER_HEALTH_CHECK_MODEL=gpt-4o-mini

# ── 成本控制（可选） ───────────────────────────────────────────────────────
# COST_CONTROL_MONTHLY_BUDGET=100
# COST_CONTROL_WARN_THRESHOLD=0.8
