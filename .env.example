# =============================================================================
# AI Gateway — 环境变量配置
# =============================================================================
# 复制此文件为 .env 并填入实际值:
#   cp .env.example .env
#
# 优先级: 环境变量 > 配置文件 (conf/default.json)
# =============================================================================

# ── 服务基础配置 ──────────────────────────────────────────────────────────
PORT=3000                           # 服务端口
HOST=0.0.0.0                        # 监听地址
LOG_LEVEL=info                      # 日志级别: debug | info | warn | error
NODE_ENV=development                 # 运行环境: development | production
CONFIG_PATH=./conf/default.json     # 配置文件路径

# ── Provider API Keys ─────────────────────────────────────────────────────
# OpenAI / OpenAI 兼容接口
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Mistral
MISTRAL_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Groq
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Google / Gemini
GOOGLE_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Moonshot (Kimi)
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# Volcano Engine (字节跳动)
VOLCANO_API_KEY=ark-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VOLCANO_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# Kimi Code
KIMI_CODE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1

# Cohere
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COHERE_BASE_URL=https://api.cohere.com/v1

# Together AI
TOGETHER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TOGETHER_BASE_URL=https://api.together.xyz/v1

# Azure OpenAI
AZURE_OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AZURE_OPENAI_BASE_URL=https://your-resource.openai.azure.com
AZURE_OPENAI_RESOURCE=your-resource
AZURE_OPENAI_DEPLOYMENT=your-deployment

# xAI (Grok)
XAI_API_KEY=xai-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
XAI_BASE_URL=https://api.x.ai/v1

# ── 网关 API Keys（多个用逗号分隔） ────────────────────────────────────────
# 客户端调用网关时的认证凭据，可在 conf/default.json 的 auth.api_keys 中配置更多
API_KEYS=sk-gateway-key-1,sk-gateway-key-2

# 管理员 API Keys（多个用逗号分隔，拥有管理后台权限）
# API_ADMIN_KEYS=sk-admin-key-1,sk-admin-key-2

# ── Redis 配置 ─────────────────────────────────────────────────────────────
# 方式一: 直接使用 URL（优先级高）
# REDIS_URL=redis://:password@localhost:6379/0

# 方式二: 逐项配置
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0
# REDIS_PREFIX=gateway
# REDIS_MAX_RETRIES=3

# ── 各模块存储后端 ────────────────────────────────────────────────────────
# 默认使用内存存储，设为 'redis' 切换到 Redis
STORAGE_TYPE=memory                  # 全局默认存储: memory | redis
CACHE_STORAGE=memory                 # 缓存存储
HISTORY_STORAGE=memory               # 会话历史存储
METRICS_STORAGE=memory               # 用量统计存储
RATE_LIMIT_STORAGE=memory            # 限流存储（设为 redis 启用分布式限流）
FAILOVER_STORAGE=memory              # Failover 健康状态存储
ALERT_STORAGE=memory                 # 告警规则状态存储
TENANT_STORAGE=memory                # 租户数据存储
QUOTA_STORAGE=memory                 # 配额状态存储

# ── Failover 配置（可选） ─────────────────────────────────────────────────
# FAILOVER_ENABLED=false
# FAILOVER_FAILURE_THRESHOLD=3
# FAILOVER_SUCCESS_THRESHOLD=2
# FAILOVER_HEALTH_CHECK_INTERVAL=60000
# FAILOVER_HEALTH_CHECK_TIMEOUT=5000
# FAILOVER_HEALTH_CHECK_MODEL=gpt-4o-mini

# ── 成本控制（可选） ───────────────────────────────────────────────────────
# COST_CONTROL_MONTHLY_BUDGET=100
# COST_CONTROL_WARN_THRESHOLD=0.8

# ── 内容安全 Guardrails ────────────────────────────────────────────────────
# PII 检测与脱敏
# GUARDRAIL_PII_ENABLED=false
# GUARDRAIL_PII_ACTION=mask          # mask | block | log_only
# GUARDRAIL_PII_RULES=email,phone_cn,id_card,credit_card,ip_address,api_key

# 提示注入检测
# GUARDRAIL_PROMPT_INJECTION_ENABLED=false
# GUARDRAIL_PROMPT_INJECTION_LEVEL=medium   # low | medium | high

# ── 审计日志 ───────────────────────────────────────────────────────────────
# LOG_DIR=./logs
# AUDIT_LOG_RETENTION_DAYS=90

# ── OpenTelemetry Tracing ──────────────────────────────────────────────────
# OTEL_ENABLED=false
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# OTEL_SERVICE_NAME=ai-gateway
# OTEL_TRACE_SAMPLER_RATIO=0.1

# ── 语义缓存 ───────────────────────────────────────────────────────────────
# SEMANTIC_CACHE_ENABLED=false
# SEMANTIC_CACHE_THRESHOLD=0.85
# SEMANTIC_CACHE_BACKEND=memory      # memory | redis_vector
# SEMANTIC_CACHE_MAX_ENTRIES=10000

# ── 嵌入服务（语义缓存依赖） ────────────────────────────────────────────────
# EMBEDDING_ENABLED=true
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EMBEDDING_BASE_URL=https://api.openai.com/v1

# ── HTTP 连接池 ────────────────────────────────────────────────────────────
# HTTP_POOL_SIZE=100
# HTTP_KEEP_ALIVE=true
# HTTP_KEEP_ALIVE_TIMEOUT=60000

# ── 告警引擎 ───────────────────────────────────────────────────────────────
# ALERT_ENABLED=false
# ALERT_CHECK_INTERVAL=60000
# ALERT_WEBHOOK_URL=https://hooks.slack.com/services/xxx
