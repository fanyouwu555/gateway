{
  "port": 3000,
  "host": "0.0.0.0",
  "log_level": "info",
  "providers": {
    "volcano": {
      "provider": "volcano",
      "base_url": "https://ark.cn-beijing.volces.com/api/coding/v3",
      "timeout": 30000
    },
    "volcano-chat": {
      "provider": "volcano",
      "base_url": "https://ark.cn-beijing.volces.com/api/v3",
      "timeout": 30000
    },
    "kimi-code": {
      "provider": "kimi-code",
      "base_url": "https://api.moonshot.cn/v1",
      "timeout": 30000
    }
  },
  "routing": [
    {
      "name": "default",
      "rules": [
        { "model": "ark-code-latest", "provider": "volcano", "max_tokens": 128000 },
        { "model": "kimi-for-coding", "provider": "kimi-code", "max_tokens": 128000 },
        { "model": "kimi-k2.6", "provider": "moonshot", "max_tokens": 128000 }
      ],
      "fallback": "volcano",
      "long_text_threshold": 5000
    }
  ],
  "model_pools": {
    "smart-chat": {
      "name": "smart-chat",
      "description": "通用对话，自动选择最优供应商",
      "capabilities": ["chat", "streaming", "function_call"],
      "candidates": [
        { "provider": "volcano-chat", "model": "doubao-pro-128k-240515", "priority": 1, "enabled": false },
        { "provider": "moonshot", "model": "kimi-k2.6", "priority": 2 }
      ]
    },
    "vision-chat": {
      "name": "vision-chat",
      "description": "多模态对话，支持图片输入",
      "capabilities": ["chat", "streaming", "vision", "function_call"],
      "candidates": [
        { "provider": "openai", "model": "gpt-4o", "priority": 1 },
        { "provider": "anthropic", "model": "claude-3-5-sonnet-20241022", "priority": 2 }
      ]
    }
  },
  "model_capabilities": {
    "gpt-4o": { "chat": true, "embed": true, "streaming": true, "vision": true, "function_call": true, "reasoning": true },
    "gpt-4o-mini": { "chat": true, "embed": true, "streaming": true, "vision": true, "function_call": true, "reasoning": true },
    "claude-3-5-sonnet-20241022": { "chat": true, "embed": false, "streaming": true, "vision": true, "function_call": true, "reasoning": true },
    "claude-3-opus-20240229": { "chat": true, "embed": false, "streaming": true, "vision": true, "function_call": true, "reasoning": true },
    "deepseek-chat": { "chat": true, "embed": true, "streaming": true, "vision": false, "function_call": true, "reasoning": true },
    "deepseek-reasoner": { "chat": true, "embed": false, "streaming": true, "vision": false, "function_call": false, "reasoning": true },
    "kimi-k2.6": { "chat": true, "embed": false, "streaming": true, "vision": true, "function_call": true, "reasoning": true },
    "kimi-for-coding": { "chat": true, "embed": false, "streaming": true, "vision": true, "function_call": true, "reasoning": true }
  },
  "auth": {
    "enabled": true,
    "api_keys": []
  },
  "rate_limit": {
    "enabled": true,
    "qps": 10,
    "burst": 20
  },
  "failover": {
    "enabled": true,
    "failureThreshold": 3,
    "successThreshold": 2,
    "healthCheckInterval": 60000,
    "healthCheckTimeout": 5000,
    "healthCheckModel": "ark-code-latest",
    "chains": {
      "volcano": ["kimi-code"],
      "kimi-code": ["volcano"]
    },
    "errorRateThreshold": 0.5,
    "latencyThresholdMs": 30000
  },
  "loadBalance": {
    "strategy": "roundRobin"
  },
  "cache": {
    "enabled": true,
    "ttl": 3600000,
    "max_size": 1000
  },
  "request_logging": {
    "enabled": true,
    "max_body_size": 4096,
    "sample_rate": 1.0
  },
  "conversation_logging": {
    "enabled": true,
    "max_memory_sessions": 100,
    "redis_ttl_days": 0,
    "max_turns_per_session": 500
  },
  "model_equivalents": {
    "ark-code-latest": {
      "kimi-code": "kimi-for-coding"
    },
    "kimi-for-coding": {
      "volcano": "ark-code-latest"
    }
  },
  "plan_defaults": {
    "free": { "daily_requests": 1000, "daily_tokens": 100000, "max_api_keys": 5, "concurrent_requests": 10 },
    "pro": { "daily_requests": 10000, "daily_tokens": 1000000, "max_api_keys": 20, "concurrent_requests": 50 },
    "enterprise": { "daily_requests": 100000, "daily_tokens": 10000000, "max_api_keys": 100, "concurrent_requests": 200 }
  },
  "rate_limit_clean_interval": 60000,
  "pricing": {
    "ark-code-latest": { "input": 0.5, "output": 2.0 },
    "kimi-for-coding": { "input": 0.5, "output": 2.0 },
    "kimi-k2.6": { "input": 0.5, "output": 2.0 },
    "gpt-4o": { "input": 2.5, "output": 10.0 },
    "gpt-4o-mini": { "input": 0.15, "output": 0.6 },
    "claude-3-opus": { "input": 15.0, "output": 75.0 },
    "claude-3-sonnet": { "input": 3.0, "output": 15.0 },
    "claude-3-haiku": { "input": 0.25, "output": 1.25 },
    "deepseek-chat": { "input": 0.14, "output": 0.28 }
  }
}