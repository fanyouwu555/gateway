{
  "port": 3000,
  "host": "0.0.0.0",
  "log_level": "info",
  "providers": {
    "volcano": {
      "provider": "volcano",
      "base_url": "https://ark.cn-beijing.volces.com/api/coding/v3",
      "timeout": 30000
    },
    "kimi-code": {
      "provider": "kimi-code",
      "base_url": "https://api.kimi.com/coding/v1",
      "timeout": 30000
    }
  },
  "routing": [
    {
      "name": "default",
      "rules": [
        { "model": "ark-code-latest", "provider": "volcano", "max_tokens": 128000 },
        { "model": "kimi-for-coding", "provider": "kimi-code", "max_tokens": 128000 }
      ],
      "fallback": "volcano"
    }
  ],
  "auth": {
    "enabled": true,
    "api_keys": [
      {
        "key": "gateway-test-key-123",
        "tenant_id": "default",
        "name": "test-key",
        "created_at": 1735689600000
      },
      {
        "key": "admin-dashboard-key-456",
        "tenant_id": "admin",
        "name": "admin-dashboard",
        "created_at": 1735689600000,
        "is_admin": true
      }
    ]
  },
  "rate_limit": {
    "enabled": true,
    "qps": 10,
    "burst": 20
  },
  "cost_control": {
    "monthly_budget": 100,
    "warn_threshold": 0.8
  },
  "failover": {
    "enabled": true,
    "failureThreshold": 3,
    "successThreshold": 2,
    "healthCheckInterval": 60000,
    "healthCheckTimeout": 5000,
    "healthCheckModel": "ark-code-latest",
    "chains": {
      "volcano": ["kimi-code"],
      "kimi-code": ["volcano"]
    },
    "errorRateThreshold": 0.5,
    "latencyThresholdMs": 30000
  },
  "loadBalance": {
    "strategy": "roundRobin",
    "providers": {}
  },
  "cache": {
    "enabled": true,
    "ttl": 3600000,
    "max_size": 1000
  },
  "request_logging": {
    "enabled": false,
    "max_body_size": 4096,
    "sample_rate": 1.0
  },
  "model_equivalents": {
    "ark-code-latest": {
      "kimi-code": "kimi-for-coding"
    },
    "kimi-for-coding": {
      "volcano": "ark-code-latest"
    }
  },
  "session": {
    "max_sessions": 1000,
    "max_messages_per_session": 100,
    "ttl": 3600000
  },
  "rate_limit_clean_interval": 60000,
  "pricing": {
    "ark-code-latest": { "input": 0.5, "output": 2.0 }
  }
}