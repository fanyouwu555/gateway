{
  "port": 3000,
  "host": "0.0.0.0",
  "log_level": "info",
  "providers": {
    "openai": {
      "provider": "openai",
      "base_url": "https://api.openai.com/v1",
      "timeout": 30000
    },
    "deepseek": {
      "provider": "deepseek",
      "base_url": "https://api.deepseek.com/v1",
      "timeout": 30000
    },
    "anthropic": {
      "provider": "anthropic",
      "base_url": "https://api.anthropic.com",
      "timeout": 30000
    }
  },
  "routing": [
    {
      "name": "default",
      "rules": [
        { "model": "gpt-4o", "provider": "openai", "max_tokens": 128000 },
        { "model": "gpt-4o-mini", "provider": "openai", "max_tokens": 4096 },
        { "model": "gpt-3.5-turbo", "provider": "openai", "max_tokens": 4096 },
        { "model": "gpt-4-turbo", "provider": "openai", "max_tokens": 128000 },
        { "model": "deepseek-chat", "provider": "deepseek", "max_tokens": 4096 },
        { "model": "deepseek-coder", "provider": "deepseek", "max_tokens": 4096 },
        { "model": "claude-3-5-sonnet-20241022", "provider": "anthropic", "max_tokens": 4096 },
        { "model": "claude-3-opus-20240229", "provider": "anthropic", "max_tokens": 4096 },
        { "model": "claude-3-sonnet-20240229", "provider": "anthropic", "max_tokens": 4096 }
      ],
      "fallback": "openai"
    }
  ],
  "auth": {
    "enabled": true,
    "api_keys": []
  },
  "rate_limit": {
    "enabled": true,
    "qps": 10,
    "burst": 20
  },
  "cost_control": {
    "monthly_budget": 100,
    "warn_threshold": 0.8
  }
}